{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/client/src/*"],
      "@shared/*": ["shared/*"]
    }
  }
}